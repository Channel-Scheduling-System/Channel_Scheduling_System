{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "rootDir": ".",
        "outDir": "dist",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "strict": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "noImplicitAny": true,
        "baseUrl": ".",
        "paths": {
            "#/*": ["./src/*"],
            "@prisma/*": ["generated/client/*"]
        }
    },
    "include": ["src", "prisma.config.ts"],
    "exclude": ["node_modules", "dist"]
}
